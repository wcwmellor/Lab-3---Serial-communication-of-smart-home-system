#include "mbed.h"
#include "arm_book_lib.h"

DigitalOut gasalarm(LED1);
DigitalOut tempalarm(LED3);
UnbufferedSerial uartUsb(USBTX, USBRX, 115200);

bool gasalarmON = false;
bool tempalarmOn = false;
bool monitoring = false;
int continuousTimer = 0;

void outputsInit();
void uartTask();
void continuousMonitoringTask();
void availableCommands();

int main()
{
    outputsInit();
    
    while (true) {
        uartTask();
        continuousMonitoringTask();
        
        
        if ( gasalarmON ) {
            gasalarm = ON;
        } else {
            gasalarm = OFF;
        }

        if ( tempalarmOn ) {
            tempalarm = ON;
        } else {
            tempalarm = OFF;
        }

        ThisThread::sleep_for(50ms);
    }
}

void outputsInit()
{
    gasalarm = OFF;
    tempalarm = OFF;
}

void uartTask()
{
    char receivedChar = '\0';
    if( uartUsb.readable() ) {
        uartUsb.read( &receivedChar, 1 );
        uartUsb.write( "\r\n", 2 );

        if ( receivedChar == '1') {
            gasalarmON = !gasalarmON;
            if ( gasalarmON ) {
                uartUsb.write( "WARNING: GAS DETECTED\r\n", 23 );
            }
        } else if ( receivedChar == '2') {
            if ( gasalarmON ) {
                uartUsb.write( "GAS ALARM ACTIVE\r\n", 18 );
            } else {
                uartUsb.write( "GAS ALARM CLEAR\r\n", 17 );
            }
        } else if ( receivedChar == '4') {
            if ( tempalarmOn ) {
                uartUsb.write( "TEMP ALARM ACTIVE\r\n", 19 );
            } else {
                uartUsb.write( "TEMP ALARM CLEAR\r\n", 18 );
            }
        } else if ( receivedChar == '3') {
            tempalarmOn = !tempalarmOn;
            if ( tempalarmOn ) {
                uartUsb.write( "WARNING: TEMPERATURE TOO HIGH\r\n", 31 );
            }
        } else if ( receivedChar == '5') {
            gasalarmON = false;
            tempalarmOn = false;
            uartUsb.write( "ALARMS RESET\r\n", 14 );
        } else if ( receivedChar == '6') {
            monitoring = !monitoring;
            continuousTimer = 0; 
            if ( monitoring ) {
                uartUsb.write( "Continuous Monitoring ON\r\n", 26 );
            } else {
                uartUsb.write( "Continuous Monitoring OFF\r\n", 27 );
            }
        } else {
            availableCommands();
        }
    }
}

void continuousMonitoringTask()
{
    if ( monitoring ) {
        continuousTimer++;
        
        if ( continuousTimer >= 40 ) { 
            if ( gasalarmON ) {
                uartUsb.write( "GAS ALARM ACTIVE\r\n", 18 );
            } else {
                uartUsb.write( "GAS ALARM CLEAR\r\n", 17 );
            }

            if ( tempalarmOn ) {
                uartUsb.write( "TEMP ALARM ACTIVE\r\n", 19 );
            } else {
                uartUsb.write( "TEMP ALARM CLEAR\r\n", 18 );
            }
            
            continuousTimer = 0;
        }
    }
}

void availableCommands()
{
    uartUsb.write( "Available commands:\r\n", 21 );
    uartUsb.write( "1: Toggle Gas Alarm\r\n", 21 );
    uartUsb.write( "2: Get Gas State\r\n", 18 );
    uartUsb.write( "3: Get Temp State\r\n", 19 );
    uartUsb.write( "4: Toggle Temp Alarm\r\n", 22 );
    uartUsb.write( "5: Reset Alarms\r\n", 17 );
    uartUsb.write( "6: Toggle Monitoring\r\n\r\n", 24 );
}
